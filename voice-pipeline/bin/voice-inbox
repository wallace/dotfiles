#!/usr/bin/env bash
# voice-inbox - manually process every unprocessed transcript in the Inbox.
#
# Public-repo safe: the Inbox location comes from $VAULT_INBOX (or the private
# config ~/.config/voice-pipeline/env), never from this file.
#
# Skips README, generated "- Summary"/"- Clean" files, and any transcript whose
# "<stem> - Summary.md" already exists - so re-running is always safe.
#
# Usage:
#   voice-inbox                  # process everything unprocessed (two-pass)
#   voice-inbox --dry-run        # just list what would be processed
#   voice-inbox --single-pass    # extra flags pass through to voice-transcript
set -uo pipefail

CONF="$HOME/.config/voice-pipeline/env"
if [[ -z "${VAULT_INBOX:-}" && -f "$CONF" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$CONF"
  set +a
fi
INBOX="${VAULT_INBOX:?Set VAULT_INBOX (zshrc export or ~/.config/voice-pipeline/env)}"

DRY=0
ARGS=(--clean-transcript)
for a in "$@"; do
  case "$a" in
    --dry-run) DRY=1 ;;
    *) ARGS+=("$a") ;;
  esac
done

# Ingest: MacWhisper's watch-folder export writes each transcript .md NEXT TO
# the audio in untranscribed/ (the destination is not configurable), so sweep
# them into the Inbox first. Settle guard (-mmin +1) avoids mid-write files;
# existing Inbox names are never overwritten.
if [[ -n "${UNTRANSCRIBED_DIR:-}" && -d "$UNTRANSCRIBED_DIR" ]]; then
  swept=0
  while IFS= read -r -d '' m; do
    b="$(basename "$m")"
    if [[ -e "$INBOX/$b" ]]; then
      echo "skip ingest: $b (already in Inbox)"
      continue
    fi
    if [[ $DRY -eq 1 ]]; then
      echo "would ingest: $b"
      continue
    fi
    mv "$m" "$INBOX/$b"
    swept=$((swept + 1))
    echo "ingested: $b"
  done < <(find "$UNTRANSCRIBED_DIR" -maxdepth 1 -type f -iname "*.md" \
             -mmin +1 -print0 2>/dev/null)
  (( swept > 0 )) && echo "ingested $swept transcript(s) from untranscribed/" && echo

  # Audio archival (TCC-safe complement to cleanup-transcribed.sh): once a
  # transcript is in the Inbox, move its source audio into the vault audio
  # folder so clickable timestamps resolve. Needs VOICE_PIPELINE_AUDIO_ARCHIVE.
  if [[ -n "${VOICE_PIPELINE_AUDIO_ARCHIVE:-}" && $DRY -eq 0 ]]; then
    mkdir -p "$VOICE_PIPELINE_AUDIO_ARCHIVE"
    while IFS= read -r -d '' a; do
      s="$(basename "$a")"
      s="${s%.*}"
      if [[ -e "$INBOX/$s.md" || -e "$INBOX/../$s.md" ]]; then
        if [[ -e "$VOICE_PIPELINE_AUDIO_ARCHIVE/$(basename "$a")" ]]; then
          rm "$a"
          echo "audio: removed duplicate $(basename "$a") (already archived)"
        else
          mv "$a" "$VOICE_PIPELINE_AUDIO_ARCHIVE/"
          echo "audio: archived $(basename "$a") -> vault"
        fi
      fi
    done < <(find "$UNTRANSCRIBED_DIR" -maxdepth 1 -type f \
               \( -iname "*.mp3" -o -iname "*.m4a" -o -iname "*.wav" \) \
               -mmin +1 -print0 2>/dev/null)
  fi

  # Delivery watchdog: audio >30 min old with no transcript beside it, in the
  # Inbox, or in the archive means MacWhisper isn't transcribing - warn loudly
  # (the old REST delivery once failed silently for three weeks).
  stale=0
  while IFS= read -r -d '' a; do
    s="$(basename "$a")"
    s="${s%.*}"
    if [[ ! -e "$UNTRANSCRIBED_DIR/$s.md" && ! -e "$INBOX/$s.md"
          && ! -e "$INBOX/../$s.md" ]]; then
      echo "WARN: '$s' has audio >30 min old but no transcript anywhere"
      stale=$((stale + 1))
    fi
  done < <(find "$UNTRANSCRIBED_DIR" -maxdepth 1 -type f \
             \( -iname "*.mp3" -o -iname "*.m4a" -o -iname "*.wav" \) \
             -mmin +30 -print0 2>/dev/null)
  if (( stale > 0 )); then
    echo "WARN: $stale file(s) may be stuck - check MacWhisper (running? watch folder? export format enabled?)"
    echo
  fi
fi

# Collapsed-timestamp detector: a healthy transcript's *MM:SS* markers climb
# across the recording. When they freeze near the start (VBR header confusing
# MacWhisper) the whole pipeline degrades silently - few speakers, no usable
# seek links. Warn when the last timestamp is under 2 min but the file has many
# segments (i.e. it's clearly longer than that).
shopt -s nullglob
for m in "$INBOX"/*.md; do
  case "$(basename "$m")" in *" - "*|README.md) continue ;; esac
  last="$(grep -oE '^\*[0-9:]+\*$' "$m" | tail -1 | tr -d '*')"
  segs="$(grep -cE '^\*[0-9:]+\*$' "$m")"
  [[ -z "$last" ]] && continue
  IFS=: read -ra p <<< "$last"
  if (( ${#p[@]} == 2 )); then secs=$(( 10#${p[0]}*60 + 10#${p[1]} ))
  else secs=$(( 10#${p[0]}*3600 + 10#${p[1]}*60 + 10#${p[2]} )); fi
  if (( segs > 60 && secs < 120 )); then
    echo "WARN: $(basename "$m") timestamps stall at ${last} across ${segs} segments"
    echo "      -> likely VBR-header / collapsed timestamps; re-encode the audio (CBR) and re-transcribe"
  fi
done

candidates=()
for f in "$INBOX"/*.md; do
  base="$(basename "$f" .md)"
  [[ "$base" == "README" ]] && continue
  [[ "$base" == *" - Summary"* || "$base" == *" - Clean"* ]] && continue
  [[ -e "$INBOX/$base - Summary.md" ]] && continue
  candidates+=("$f")
done

if [[ ${#candidates[@]} -eq 0 ]]; then
  echo "Inbox clean: nothing to process."
  exit 0
fi

echo "Unprocessed (${#candidates[@]}):"
for f in "${candidates[@]}"; do echo "  $(basename "$f")"; done
if [[ $DRY -eq 1 ]]; then
  exit 0
fi

ok=0
fail=0
for f in "${candidates[@]}"; do
  echo
  echo "=== $(basename "$f") ==="
  if voice-transcript "$f" ${VOICE_PIPELINE_AUDIO_ARCHIVE:+--audio-dir "$VOICE_PIPELINE_AUDIO_ARCHIVE"} "${ARGS[@]}"; then
    ok=$((ok + 1))
  else
    fail=$((fail + 1))
    echo "FAILED: $(basename "$f")"
  fi
done

echo
echo "Done: $ok succeeded, $fail failed."
[[ $fail -eq 0 ]]
